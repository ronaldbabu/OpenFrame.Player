<Window x:Class="OpenFrame.Player.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        mc:Ignorable="d"
        Title="OpenFrame"
        Height="600"
        Width="1000"
        MinHeight="420"
        MinWidth="720">

    <DockPanel Background="#101214">
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_Open"
                          Command="{Binding OpenCommand}"/>
            </MenuItem>
        </Menu>

        <Grid DockPanel.Dock="Bottom"
              Background="#1B1E22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Margin="12,8,12,0"
                       Foreground="#F87171"
                       Text="{Binding ErrorMessage}"
                       TextWrapping="Wrap">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasError}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <Grid Grid.Row="1"
                  Margin="12,10,12,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="120"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        MinWidth="72"
                        Margin="0,0,8,0"
                        Padding="10,5"
                        Command="{Binding OpenCommand}"
                        Content="Open"/>

                <Button Grid.Column="1"
                        MinWidth="72"
                        Margin="0,0,8,0"
                        Padding="10,5"
                        Command="{Binding PlayPauseCommand}"
                        Content="{Binding PlayPauseText}"/>

                <Button Grid.Column="2"
                        MinWidth="72"
                        Margin="0,0,12,0"
                        Padding="10,5"
                        Command="{Binding StopCommand}"
                        Content="Stop"/>

                <StackPanel Grid.Column="3"
                            Margin="0,0,12,0">
                    <TextBlock Foreground="#D8DEE9"
                               FontSize="12"
                               Text="{Binding SelectedMediaName, TargetNullValue=No media selected}"
                               TextTrimming="CharacterEllipsis"/>
                    <Slider Margin="0,4,0,0"
                            IsEnabled="{Binding HasMedia}"
                            Minimum="0"
                            Maximum="{Binding DurationMilliseconds}"
                            Value="{Binding PositionMilliseconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Foreground="#A7B0BB"
                               FontSize="11"
                               Text="{Binding StatusMessage}"/>
                </StackPanel>

                <TextBlock Grid.Column="4"
                           Margin="0,0,8,0"
                           VerticalAlignment="Center"
                           Foreground="#D8DEE9"
                           Text="Volume"/>

                <Slider Grid.Column="5"
                        Minimum="0"
                        Maximum="100"
                        VerticalAlignment="Center"
                        Value="{Binding Volume, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>
        </Grid>

        <Border Background="Black">
            <vlc:VideoView x:Name="VideoView"/>
        </Border>
    </DockPanel>
</Window>
